{
  "name": "cybervault-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && powershell -ExecutionPolicy Bypass -File scripts/postbuild-dist-htaccess.ps1",
    "build:static": "vite build && powershell -ExecutionPolicy Bypass -File scripts/postbuild-dist-htaccess.ps1",
    "preview": "vite preview",
    "release:zip": "powershell -ExecutionPolicy Bypass -File scripts/prepare-static-release.ps1",
    "release:source": "powershell -ExecutionPolicy Bypass -File scripts/prepare-source-package.ps1",
    "release:cyberpanel": "powershell -ExecutionPolicy Bypass -File scripts/prepare-cyberpanel-deploy.ps1"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.8"
  }
}
